{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "Vite Preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 4173
    },
    {
      "name": "Firebase Emulator Suite",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["emulators:start", "--only=auth,firestore,storage,functions"],
      "port": 4400
    }
  ]
}
