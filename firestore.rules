rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function touchesProtectedUserFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'plan',
        'isPro',
        'isAdmin',
        'proSince',
        'proExpiresAt',
        'stripeCustomerId',
        'stripeSubscriptionId',
        'billingCountry',
        'billingCurrency',
        'priceTier',
        'firstPaidAt'
      ]);
    }
    function createsSafeUserProfile() {
      return request.resource.data.keys().hasOnly([
        'name',
        'email',
        'avatar',
        'gender',
        'birthDate',
        'location',
        'bio',
        'website',
        'instagramHandle',
        'skillLevel',
        'onboardingCompleted',
        'primaryInterest',
        'bakingFrequency',
        'enableSmartSchedule',
        'trials',
        'createdAt',
        'updatedAt'
      ]);
    }

    // User Profile (Private, but entitlements are backend-only)
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && createsSafeUserProfile();
      allow update: if isOwner(userId) && !touchesProtectedUserFields();
      allow delete: if false;
    }

    // User Data (Private)
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
    
    // --- Organizations / Tenancy (Future-proofing) ---
    match /organizations/{orgId}/{document=**} {
       allow read, write: if belongsToTenant(orgId);
    }

    // --- Community: Posts ---
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      // Allow update if owner OR if only updating counters (likes/comments)
      allow update: if isSignedIn(); // Simplified for now to ensure counters work
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // --- Community: Comments ---
    match /community_comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // --- Community: Likes & Stats ---
    match /community_likes/{likeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /community_clones/{cloneId} {
       allow read: if true;
       allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /community_follows/{followId} {
       allow read: if true;
       allow write: if isSignedIn();
    }
    
    // Fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
