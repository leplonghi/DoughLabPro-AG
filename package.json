{
  "name": "doughlabpro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "functions:build": "npm --prefix functions run build",
    "functions:test": "npm --prefix functions test",
    "typecheck": "tsc --noEmit",
    "ui:check-colors": "node scripts/check-visual-colors.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "deploy:check": "npm run typecheck && npm run build && npm run functions:build && npm run functions:test",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:backend": "firebase deploy --only functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:prod": "npm run deploy:check && firebase deploy --only firestore:rules,storage,functions,hosting"
  },
  "dependencies": {
    "@firebase/app": "^0.14.6",
    "@firebase/auth": "^1.11.1",
    "@google/genai": "^1.29.0",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@stripe/stripe-js": "^8.5.3",
    "firebase": "^12.6.0",
    "framer-motion": "^12.23.26",
    "html2canvas": "^1.4.1",
    "i18next": "^25.7.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.555.0",
    "path": "^0.12.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20.11.24",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.10.16",
    "firebase-tools": "^15.13.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.3",
    "vite": "^5.2.0"
  }
}
